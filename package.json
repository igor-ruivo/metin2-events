{
	"name": "metin2-events",
	"version": "1.0.0",
	"description": "A discord bot for alerting about events in Metin2",
	"scripts": {
		"now": "tsx src/bin/now.ts",
		"weekly": "tsx src/bin/weekly.ts",
		"daily": "tsx src/bin/daily.ts",
		"monthly": "tsx src/bin/monthly.ts",
		"next": "tsx src/bin/next.ts",
		"register": "tsx src/bin/register.ts",
		"refresh": "tsx src/bin/refresh.ts",
		"update": "tsx src/bin/update.ts",
		"list": "tsx src/bin/list.ts",
		"lint": "npx eslint --fix --ext .ts ./src ./api ./eslint.config.cjs ./prettier.config.cjs ./package.json ./tsconfig.json 2>&1 && pnpm run format && pnpm tsc --noEmit",
		"format": "npx prettier --write \"src/**/*.{ts,js,json,css,md}\" \"api/**/*.{ts,js,json,css,md}\" *.json *.md *.cjs",
		"build": "pnpm tsc",
		"debug": "npx tsx --inspect-brk src/bin/now.ts"
	},
	"keywords": [
		"metin2",
		"events",
		"discord",
		"bot"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@types/jsdom": "^28.0.1",
		"discord-interactions": "^4.4.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"jsdom": "^29.1.1",
		"node-cron": "^4.2.1",
		"vercel": "^53.2.0"
	},
	"devDependencies": {
		"@ti-platform/aide-build-tools": "^5.2.0",
		"@tsconfig/recommended": "^1.0.13",
		"@types/node": "^25.6.0",
		"@types/node-cron": "^3.0.11",
		"@typescript-eslint/parser": "^8.59.2",
		"eslint": "^10.3.0",
		"eslint-plugin-promise": "^7.3.0",
		"prettier": "^3.8.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2"
	}
}
